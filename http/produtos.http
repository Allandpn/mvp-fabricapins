### LISTAR
GET {{baseUrl}}/produtos?page=0&size=10


### CRIAR
POST {{baseUrl}}/produtos
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nome": "Pin Girassol",
  "descricao": "Pin dourado metálico 30x13x2mm com acabamento esmaltado",
  "tipoEstoque": "ESTOQUE",
  "quantidadeEstoque": 100,
  "estoqueMinimo": 10,
  "precoVarejo": 19.90,
  "precoRevenda": 12.50,
  "custoProducao": 5.1234,
  "dataPrevistaLancamento": "2026-06-01",
  "sku": "PIN-GIRASSOL-001",
  "imgUrl": "images/produto-123.jpg",
  "peso": 13.0,
  "altura": 10,
  "largura": 20,
  "comprimento": 30,
  "ativo": true,
  "categoriaId": 2
}

> {%
    client.global.set("produtoId", response.body.id);
%}

### BUSCAR
GET {{baseUrl}}/produtos/{{produtoId}}
Content-Type: application/json
Authorization: Bearer {{token}}

### ATUALIZAR
PUT {{baseUrl}}/produtos/{{produtoId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nome": "Produto Editado",
  "descricao": "Desc edit",
  "peso": 12,
  "categoriaId": 1
}

### DELETE
DELETE {{baseUrl}}/produtos/{{produtoId}}
Authorization: Bearer {{token}}


### LISTAR
GET {{baseUrl}}/produtos/{{produtoId}}/variacoes

### CRIAR
POST {{baseUrl}}/produtos/{{produtoId}}/variacoes
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nome": "Variacao",
  "descricao": "Desc",
  "tipoEstoque": "ESTOQUE",
  "precoVarejo": 10,
  "precoRevenda": 8,
  "custoProducao": 5,
  "sku": "sku123"
}

### BUSCAR
GET {{baseUrl}}/produtos/{{produtoId}}/variacoes/{{variacaoId}}

### ATUALIZAR
PUT {{baseUrl}}/produtos/{{produtoId}}/variacoes/{{variacaoId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nome": "Variacao Edit",
  "descricao": "Desc",
  "tipoEstoque": "ESTOQUE",
  "precoVarejo": 10,
  "precoRevenda": 8,
  "custoProducao": 5,
  "sku": "sku123"
}

### DELETE
DELETE {{baseUrl}}/produtos/{{produtoId}}/variacoes/{{variacaoId}}
Authorization: Bearer {{token}}